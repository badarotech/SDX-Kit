{
  "$schema": "https://schemas.local/design-tokens",
  "meta": {
    "name": "Badaró — Foundation Tokens",
    "fonte": "Extraído do Figma (biblioteca Foundation / coleção Semantic) do arquivo 'Badaró · Novo Site 2026'.",
    "exatos": "Marca 400/50, neutros 200/500/700/800/900 e 10, preto/branco, e tipografia (Figtree, pesos, tamanhos, line-heights) vieram resolvidos do Figma.",
    "aprox": "Passos intermediários do ramp (marca 100/200/300/500/600/700/900; neutros 50/100/300/400/600) foram interpolados — confirmar no Figma quando possível.",
    "sem_dado": "Escalas de espaçamento e raio não estão expostas como variáveis na Foundation; mantidas como padrão sensato."
  },
  "color": {
    "brand": {
      "50":  "#ffddf0",
      "100": "#ffc0e3",
      "200": "#ff87c9",
      "300": "#ff4eb0",
      "400": "#ff1596",
      "500": "#e00f83",
      "600": "#b80a6b",
      "700": "#8f0653",
      "900": "#4d012b"
    },
    "neutral": {
      "10":  "#ffffff",
      "50":  "#f5f6f8",
      "100": "#e9ebef",
      "200": "#c8ccd6",
      "300": "#aeb2bf",
      "400": "#9499a7",
      "500": "#7a7f90",
      "600": "#5d6271",
      "700": "#3f4452",
      "800": "#2a2e3a",
      "900": "#060606"
    },
    "base":    { "black": "#000000", "white": "#ffffff" },
    "success": { "500": "#1d9e75", "600": "#0f6e56" },
    "warning": { "500": "#ba7517", "600": "#854f0b" },
    "danger":  { "500": "#e24b4a", "600": "#a32d2d" }
  },
  "typography": {
    "font-sans": "Figtree, system-ui, sans-serif",
    "font-mono": "'JetBrains Mono', ui-monospace, monospace",
    "size": { "xs": "12px", "sm": "14px", "md": "16px", "lg": "18px", "xl": "24px", "2xl": "32px", "3xl": "40px", "4xl": "64px" },
    "weight": { "regular": "400", "medium": "500", "semibold": "600" },
    "line-height": { "tight": "1.1", "snug": "1.2", "normal": "1.4", "relaxed": "1.55" }
  },
  "space": { "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "24px", "6": "32px", "8": "48px", "10": "64px" },
  "radius": { "sm": "6px", "md": "10px", "lg": "16px", "pill": "999px" },
  "shadow": { "sm": "0 1px 2px rgba(6,6,6,.06)", "md": "0 4px 16px rgba(6,6,6,.10)" },
  "breakpoint": { "sm": "640px", "md": "768px", "lg": "1024px" }
}
